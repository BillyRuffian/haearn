<div id="gym_machines_panel">
  <div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span><i class="bi bi-gear me-2"></i>Equipment</span>
      <div class="d-flex gap-2">
        <span class="badge bg-secondary"><%= pluralize(machines.count, "active") %></span>
        <% if retired_machines.any? %>
          <span class="badge bg-dark"><%= pluralize(retired_machines.count, "retired") %></span>
        <% end %>
      </div>
    </div>

    <div class="card-body border-bottom">
      <%= turbo_frame_tag "new_machine_form" do %>
        <%= render "machines/form", machine: new_machine, gym: gym %>
      <% end %>
    </div>

    <div id="machines" class="card-body pt-0">
      <% if machines.any? %>
        <% machines.each do |machine| %>
          <%= render "machines/machine", machine: machine, gym: gym %>
        <% end %>
      <% else %>
        <div class="text-center py-4">
          <i class="bi bi-gear display-4 text-muted"></i>
          <p class="text-muted mt-3 mb-0">No active equipment right now. Add a new piece above or reactivate retired equipment below.</p>
        </div>
      <% end %>
    </div>

    <% if retired_machines.any? %>
      <div class="card-footer border-top">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <strong class="small text-uppercase text-muted">Retired Equipment</strong>
            <div class="small text-muted">Hidden from future workout selection, preserved for history.</div>
          </div>
          <span class="badge bg-dark"><%= retired_machines.count %></span>
        </div>

        <div id="retired_machines">
          <% retired_machines.each do |machine| %>
            <%= render "machines/machine", machine: machine, gym: gym %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
